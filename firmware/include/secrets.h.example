#pragma once

// TEMPLATE — copy this file to secrets.h (gitignored) and fill in your values.

#define WIFI_SSID     "your-network-ssid"
#define WIFI_PASSWORD "your-network-password"

// Telemetry write auth. Must match the Apps Script `SHEETS_TOKEN` Script Property
// (Project Settings -> Script Properties). The firmware sends this in every POST;
// doPost() rejects writes whose token doesn't match, so the public /exec URL can't
// be used to poison the dataset. Generate with: python -c "import secrets;print(secrets.token_urlsafe(24))"
#define SHEETS_TOKEN  "your-telemetry-write-token"

