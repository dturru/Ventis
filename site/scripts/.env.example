# Copy this file to `.env` (same folder) and fill in your real values.
# `.env` is gitignored — it never reaches the repo. The CLI scripts auto-load it,
# so you never have to `export` / `$env:` these in your shell again.
#
# SUPABASE_DB_URL: from the Supabase dashboard -> Project Settings -> Database ->
#   Connection string -> SESSION POOLER (not "Direct connection" — that's IPv6-only).
#   Paste it verbatim and replace [YOUR-PASSWORD] with your DB password.
SUPABASE_DB_URL=postgresql://postgres.<your-project-ref>:<your-password>@aws-0-us-east-2.pooler.supabase.com:5432/postgres

# Optional (only needed for the Sheet pull / sync, not for annotate/consent):
# VENTIS_SHEET_ID=15IQSI9mG0o6kSeN0dp9yeawykIrqkdpGZJJCR8DcBxU
# VENTIS_SA_JSON=service_account.json
